# Copy to .dev.vars and fill in values for local development (wrangler dev)
# See wrangler.jsonc for non-secret vars (STELLAR_PAY_TO, FACILITATOR_URL)

# Optional: enables the real x402 channel payment scheme.
# Generate with: node -e "console.log(require('@stellar/stellar-sdk').Keypair.random().secret())"
CHANNEL_SERVER_SECRET=S...
CHANNEL_FACILITATOR_SECRET=S...

# Non-secret channel defaults live in wrangler.jsonc:
# CHANNEL_CONTRACT_ID=CB...
# CHANNEL_RPC_URL=https://soroban-rpc.testnet.stellar.gateway.fm/
